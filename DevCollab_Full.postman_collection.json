{
  "info": {
    "name": "DevCollab API - Full Modules",
    "description": "Comprehensive Postman collection for DevCollab including Auth, Workspace, Activity Feed, Notifications, and Billing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api", "type": "string" },
    { "key": "token", "value": "YOUR_JWT_TOKEN_HERE", "type": "string" },
    { "key": "workspaceId", "value": "YOUR_WORKSPACE_ID_HERE", "type": "string" },
    { "key": "memberId", "value": "YOUR_MEMBER_ID_HERE", "type": "string" },
    { "key": "notificationId", "value": "YOUR_NOTIFICATION_ID_HERE", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": [ "{{baseUrl}}" ], "path": [ "auth", "register" ] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@devcollab.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": [ "{{baseUrl}}" ], "path": [ "auth", "login" ] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@devcollab.com\",\n  \"password\": \"password123\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": [ "{{baseUrl}}" ], "path": [ "auth", "logout" ] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": [ "{{baseUrl}}" ], "path": [ "auth", "refresh" ] }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": [ "{{baseUrl}}" ], "path": [ "auth", "me" ] }
          }
        }
      ]
    },
    {
      "name": "2. Workspace",
      "item": [
        {
          "name": "Create Workspace",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/workspaces", "host": [ "{{baseUrl}}" ], "path": [ "workspaces" ] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"My New Workspace\",\n  \"slug\": \"my-new-workspace\"\n}" }
          }
        },
        {
          "name": "List Workspaces",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/workspaces", "host": [ "{{baseUrl}}" ], "path": [ "workspaces" ] }
          }
        },
        {
          "name": "Get Workspace",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}", "host": [ "{{baseUrl}}" ], "path": [ "workspaces", "{{workspaceId}}" ] }
          }
        },
        {
          "name": "Invite Member",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/invites", "host": [ "{{baseUrl}}" ], "path": [ "workspaces", "{{workspaceId}}", "invites" ] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"colleague@devcollab.com\",\n  \"role\": \"MEMBER\"\n}" }
          }
        },
        {
          "name": "Accept Invite",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/workspaces/invites/accept", "host": [ "{{baseUrl}}" ], "path": [ "workspaces", "invites", "accept" ] },
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"INVITE_TOKEN_RECEIVED_IN_EMAIL\"\n}" }
          }
        },
        {
          "name": "Update Member Role",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members/{{memberId}}", "host": [ "{{baseUrl}}" ], "path": [ "workspaces", "{{workspaceId}}", "members", "{{memberId}}" ] },
            "body": { "mode": "raw", "raw": "{\n  \"role\": \"ADMIN\"\n}" }
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/workspaces/{{workspaceId}}/members/{{memberId}}", "host": [ "{{baseUrl}}" ], "path": [ "workspaces", "{{workspaceId}}", "members", "{{memberId}}" ] }
          }
        }
      ]
    },
    {
      "name": "3. Activity Feed",
      "item": [
        {
          "name": "Get Activities",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/activities/{{workspaceId}}?page=1&limit=10",
              "host": [ "{{baseUrl}}" ],
              "path": [ "activities", "{{workspaceId}}" ],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "action", "value": "WORKSPACE_CREATED", "disabled": true },
                { "key": "userId", "value": "USER_ID", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": {
              "raw": "{{baseUrl}}/notifications?page=1&limit=10",
              "host": [ "{{baseUrl}}" ],
              "path": [ "notifications" ],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Unread Count",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/notifications/unread-count", "host": [ "{{baseUrl}}" ], "path": [ "notifications", "unread-count" ] }
          }
        },
        {
          "name": "Mark as Read",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/notifications/{{notificationId}}/read", "host": [ "{{baseUrl}}" ], "path": [ "notifications", "{{notificationId}}", "read" ] }
          }
        },
        {
          "name": "Mark All as Read",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/notifications/read-all", "host": [ "{{baseUrl}}" ], "path": [ "notifications", "read-all" ] }
          }
        }
      ]
    },
    {
      "name": "5. Billing",
      "item": [
        {
          "name": "Create Razorpay Order",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/billing/orders", "host": [ "{{baseUrl}}" ], "path": [ "billing", "orders" ] },
            "body": { "mode": "raw", "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"plan\": \"PRO\"\n}" }
          }
        },
        {
          "name": "Verify Payment",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/billing/verify", "host": [ "{{baseUrl}}" ], "path": [ "billing", "verify" ] },
            "body": { "mode": "raw", "raw": "{\n  \"workspaceId\": \"{{workspaceId}}\",\n  \"razorpayOrderId\": \"order_xxx\",\n  \"razorpayPaymentId\": \"pay_xxx\",\n  \"razorpaySignature\": \"sig_xxx\"\n}" }
          }
        },
        {
          "name": "Get Current Subscription",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{baseUrl}}/billing/{{workspaceId}}", "host": [ "{{baseUrl}}" ], "path": [ "billing", "{{workspaceId}}" ] }
          }
        }
      ]
    }
  ]
}
