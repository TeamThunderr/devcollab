datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client-js"
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum Plan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  avatar        String?
  bio           String?
  skills        String[]  // Array supported in PostgreSQL
  githubLink    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  refreshTokens RefreshToken[]
  ownedWorkspaces Workspace[]
  memberships   WorkspaceMember[]
  activities    Activity[]
  notifications Notification[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]
  invites     Invite[]
  activities  Activity[]
  subscription Subscription?

  @@index([slug])
  @@index([createdBy])
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  role        Role     @default(MEMBER)
  joinedAt    DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Invite {
  id          String       @id @default(uuid())
  workspaceId String
  email       String
  token       String       @unique
  role        Role         @default(MEMBER)
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@index([token])
}

model Subscription {
  id                     String             @id @default(uuid())
  workspaceId            String             @unique
  plan                   Plan               @default(FREE)
  razorpaySubscriptionId String?            @unique
  status                 SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd       DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  workspace              Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Activity {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  type        String
  message     String
  metadata    Json?
  readAt      DateTime? // Read timestamp instead of boolean
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}



model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  workspaceId String    @map("workspace_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  tasks       Task[]
  snippets    Snippet[]
  files       ProjectFile[]

  @@index([workspaceId, createdAt])
  @@map("projects")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  P0
  P1
  P2
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(P1)
  dueDate     DateTime?    @map("due_date")
  projectId   String       @map("project_id")
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments    Comment[]
  files       ProjectFile[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([projectId, createdAt])
  @@index([projectId, status])
  @@index([projectId, priority])
  @@map("tasks")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  taskId     String   @map("task_id")
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([taskId, createdAt])
  @@map("comments")
}

model Snippet {
  id          String   @id @default(cuid())
  title       String
  language    String
  code        String
  description String?
  tags        String[] @default([])
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([projectId, createdAt])
  @@index([projectId, title])
  @@map("snippets")
}

model ProjectFile {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId    String?  @map("parent_id")
  name        String
  type        String   @default("file")
  content     String?  @default("")
  language    String?  @default("plaintext")
  createdBy   String?  @map("created_by")
  taskId      String?  @map("linkedTaskId")
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("files")
}

model WikiPage {
  id           String        @id @default(cuid())
  workspaceId  String        @map("workspace_id")
  projectId    String        @map("project_id")
  title        String        @default("Untitled")
  slug         String        @unique
  content      String        @default("")
  linkedTaskId String?       @map("linked_task_id")
  linkedFileId String?       @map("linked_file_id")
  createdBy    String        @map("created_by")
  updatedBy    String        @map("updated_by")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  versions     WikiVersion[]

  @@index([projectId])
  @@index([workspaceId])
  @@map("wiki_pages")
}

model WikiVersion {
  id              String   @id @default(cuid())
  pageId          String   @map("page_id")
  page            WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  contentSnapshot String   @map("content_snapshot")
  versionNumber   Int      @map("version_number")
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([pageId])
  @@map("wiki_versions")
}

