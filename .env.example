# ============================================
# AI CONFIGURATION (Module 7)
# ============================================

# Primary model: gemini-2.5-flash-preview-05-20
# Fallback model: gemini-3.1-flash-lite-preview-06-17 (500 RPD free tier)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite

# Set to true during development to avoid burning API quota
# Set to false for real AI responses (integration testing + demo)
AI_MOCK_MODE=true

